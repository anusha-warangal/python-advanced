# Day 4: Strings and User Input
name = input("Enter your name: ")
age = int(input("Enter your age: "))

# f-string = Easy way to mix text + variables
print(f"Hi {name}, you are {age} years old.")

# String methods - Useful for DA data cleaning
print(f"Uppercase: {name.upper()}")
print(f"Name length: {len(name)}")

# DA use: Age check
if age >= 18:
    print("You are eligible for DA internship.")
else:
    print("Focus on skills. Apply at 18+.")
